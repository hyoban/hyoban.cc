---
import type { ResolvedMomentMedia } from '@/moments'
import { Image } from 'astro:assets'

interface Props {
  media: ResolvedMomentMedia[]
}

const { media } = Astro.props
const galleryClass = `moment-gallery moment-gallery--${Math.min(media.length, 4)}`
const isSingle = media.length === 1
---

<div
  class:list={[
    galleryClass,
    'mt-3.5 grid gap-1 overflow-hidden',
    isSingle ? 'grid-cols-1' : 'grid-cols-2',
  ]}
>
  {
    media.map((item, index) => item.type === 'image'
      ? (
          <button
            type="button"
            class:list={[
              'moment-gallery__image min-w-0 cursor-zoom-in overflow-hidden rounded-md border-0 bg-inline p-0',
              isSingle ? 'max-h-[32rem] [aspect-ratio:auto]' : 'aspect-[4/3]',
              { 'row-span-2': media.length === 3 && index === 0 },
            ]}
            data-lightbox-item
            data-lightbox-src={item.src.src}
            data-lightbox-alt={item.alt}
            aria-label={`查看图片 ${index + 1}`}
          >
            <Image
              src={item.src}
              alt={item.alt}
              width={Math.min(item.src.width, 960)}
              height={Math.round(Math.min(item.src.width, 960) * item.src.height / item.src.width)}
              loading="lazy"
              class:list={[
                'block w-full',
                isSingle ? 'h-auto max-h-[32rem] object-contain' : 'h-full object-cover',
              ]}
            />
          </button>
        )
      : (
          <div
            class:list={[
              'moment-gallery__video min-w-0 overflow-hidden rounded-md bg-inline',
              isSingle ? 'max-h-[32rem] [aspect-ratio:auto]' : 'aspect-[4/3]',
              { 'row-span-2': media.length === 3 && index === 0 },
            ]}
          >
            <video
              controls
              preload="metadata"
              poster={item.poster?.src}
              aria-label={item.alt || `视频 ${index + 1}`}
              class:list={[
                'block w-full',
                isSingle ? 'h-auto max-h-[32rem] object-contain' : 'h-full object-cover',
              ]}
            >
              <source src={item.src} type="video/mp4" />
            </video>
          </div>
        ))
  }
</div>
