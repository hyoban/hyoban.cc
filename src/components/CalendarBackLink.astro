---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<a
  class:list={[
    'calendar-back-link inline-flex min-h-10 items-center rounded-full border border-[color-mix(in_srgb,var(--color-border)_82%,transparent)] bg-[color-mix(in_srgb,var(--color-bg)_82%,transparent)] px-3.5 text-[0.8125rem] text-tx-2 no-underline backdrop-blur-[1rem]',
    className,
  ]}
  href="/"
>
  返回
</a>
