---
import { getChinaCalendarDayDescription, type ChinaCalendarDay } from '@/china-calendar'

interface Props {
  class?: string
  compact?: boolean
  day: ChinaCalendarDay
}

const { class: className, compact = false, day } = Astro.props
const label = day.kind === 'day-off' ? day.name : `${day.name}调休`
const description = getChinaCalendarDayDescription(day)
---

<span
  class:list={[
    'calendar-day-status flex-none items-center whitespace-nowrap font-mono',
    `calendar-day-status--${day.kind}`,
    compact
      ? 'calendar-day-status--compact block max-w-full overflow-hidden text-ellipsis box-border text-[0.625rem] leading-[1.25]'
      : 'inline-flex text-[0.6875rem]',
    day.kind === 'day-off' ? 'text-tx' : 'text-tx-2',
    className,
  ]}
  aria-label={description}
  title={description}
>
  {label}
</span>
