---
import CalendarBackLink from '@/components/CalendarBackLink.astro'
import CalendarDayStatus from '@/components/CalendarDayStatus.astro'
import CalendarModeSwitch from '@/components/CalendarModeSwitch.astro'
import MobileAgenda from '@/components/MobileAgenda.astro'
import MomentEntry from '@/components/MomentEntry.astro'
import {
  getChinaCalendarDay,
  getChinaCalendarDayDescription,
  type ChinaCalendarDay,
} from '@/china-calendar'
import Layout from '@/layouts/Layout.astro'
import {
  getActiveDateKeys,
  getArchiveMonthKeys,
  getMomentDateKey,
  getMomentPath,
  getMoments,
  getMonthPath,
  type Moment,
  type ResolvedMomentMedia,
} from '@/moments'
import { SITE_TITLE } from '@/consts'
import { Image } from 'astro:assets'

interface Props {
  month: number
  selectedDate?: string
  year: number
}

type CalendarDay = {
  chinaCalendarDay: ChinaCalendarDay | undefined
  dateKey: string
  day: number
  mediaCount: number
  moments: Moment[]
  thumbnail: ResolvedMomentMedia | undefined
}

const { month, selectedDate, year } = Astro.props
const moments = await getMoments()
const activeDateKeys = getActiveDateKeys(moments)
const monthKeys = getArchiveMonthKeys(moments)
const monthKey = `${year}-${String(month).padStart(2, '0')}`
const currentMonthIndex = monthKeys.indexOf(monthKey)
const previousMonth = currentMonthIndex > 0 ? monthKeys[currentMonthIndex - 1] : undefined
const nextMonth = currentMonthIndex >= 0 && currentMonthIndex < monthKeys.length - 1
  ? monthKeys[currentMonthIndex + 1]
  : undefined
const momentsByDate = Map.groupBy(moments, moment => moment.dateKey)
const daysInMonth = new Date(Date.UTC(year, month, 0)).getUTCDate()
const firstWeekday = (new Date(Date.UTC(year, month - 1, 1)).getUTCDay() + 6) % 7
const calendarDays: Array<CalendarDay | undefined> = Array.from({ length: firstWeekday })

for (let day = 1; day <= daysInMonth; day += 1) {
  const dateKey = `${monthKey}-${String(day).padStart(2, '0')}`
  const dayMoments = momentsByDate.get(dateKey) ?? []
  const allMedia = dayMoments.flatMap(moment => moment.media)
  const thumbnail = allMedia.find(item => item.type === 'image' || item.poster)

  calendarDays.push({
    chinaCalendarDay: getChinaCalendarDay(dateKey),
    dateKey,
    day,
    mediaCount: allMedia.length,
    moments: dayMoments,
    thumbnail,
  })
}

while (calendarDays.length % 7 !== 0) {
  calendarDays.push(undefined)
}

const activeCalendarDays = calendarDays.filter(
  (day): day is CalendarDay => Boolean(day?.moments.length),
)
const today = getMomentDateKey(new Date())
const selectedMoments = selectedDate ? momentsByDate.get(selectedDate) ?? [] : []
const selectedDateIndex = selectedDate ? activeDateKeys.indexOf(selectedDate) : -1
const previousDate = selectedDateIndex > 0 ? activeDateKeys[selectedDateIndex - 1] : undefined
const nextDate = selectedDateIndex >= 0 && selectedDateIndex < activeDateKeys.length - 1
  ? activeDateKeys[selectedDateIndex + 1]
  : undefined
const groupedMonths = Map.groupBy(monthKeys, key => key.slice(0, 4))
const activeMonthKeys = new Set(activeDateKeys.map(key => key.slice(0, 7)))
const description = '一些零碎记录，按发生的日期归档。'
const selectedDateLabel = selectedDate ? formatSelectedDate(selectedDate) : undefined
const title = selectedDateLabel
  ? `${selectedDateLabel} · 日历 | ${SITE_TITLE}`
  : `${year} 年 ${month} 月 · 日历 | ${SITE_TITLE}`
const closePath = getMonthPath(monthKey)

function formatSelectedDate(dateKey: string) {
  const { dateDay, dateMonth, dateValue } = parseCalendarDate(dateKey)
  const weekday = new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Singapore',
    weekday: 'long',
  }).format(dateValue)

  return `${dateMonth} 月 ${dateDay} 日 · ${weekday}`
}

function formatCompactDate(dateKey: string) {
  return `${Number.parseInt(dateKey.slice(5, 7), 10)}/${Number.parseInt(dateKey.slice(8, 10), 10)}`
}

function parseCalendarDate(dateKey: string) {
  const dateYear = Number.parseInt(dateKey.slice(0, 4), 10)
  const dateMonth = Number.parseInt(dateKey.slice(5, 7), 10)
  const dateDay = Number.parseInt(dateKey.slice(8, 10), 10)

  return {
    dateDay,
    dateMonth,
    dateValue: new Date(Date.UTC(dateYear, dateMonth - 1, dateDay)),
  }
}

function getThumbnailImage(media?: ResolvedMomentMedia) {
  if (!media) {
    return undefined
  }

  return media.type === 'image' ? media.src : media.poster
}
---

<Layout title={title} description={description}>
  <main
    class:list={['calendar-page', { 'calendar-page--with-drawer': selectedDate }] }
    style={`--calendar-weeks: ${calendarDays.length / 7}`}
  >
    <header class="calendar-toolbar">
      <CalendarModeSwitch mode="calendar" />

      <nav class="month-navigation" aria-label="月份导航">
        {
          previousMonth
            ? <a class="month-navigation__arrow" href={getMonthPath(previousMonth)} aria-label="上一个月"><span class="i-lucide-chevron-left" aria-hidden="true" /></a>
            : <span class="month-navigation__arrow month-navigation__arrow--disabled"><span class="i-lucide-chevron-left" aria-hidden="true" /></span>
        }

        <details class="month-picker">
          <summary>{year} 年 {month} 月 <span class="i-lucide-chevron-down" aria-hidden="true" /></summary>
          <div class="month-picker__panel">
            {
              [...groupedMonths].map(([pickerYear, pickerMonths]) => (
                <section>
                  <h2>{pickerYear}</h2>
                  <div>
                    {pickerMonths.map(key => {
                      const pickerMonth = Number.parseInt(key.slice(5), 10)
                      return (
                        <a
                          href={getMonthPath(key)}
                          class:list={{
                            'is-active': key === monthKey,
                            'has-content': activeMonthKeys.has(key),
                          }}
                        >
                          {pickerMonth}
                        </a>
                      )
                    })}
                  </div>
                </section>
              ))
            }
          </div>
        </details>

        {
          nextMonth
            ? <a class="month-navigation__arrow" href={getMonthPath(nextMonth)} aria-label="下一个月"><span class="i-lucide-chevron-right" aria-hidden="true" /></a>
            : <span class="month-navigation__arrow month-navigation__arrow--disabled"><span class="i-lucide-chevron-right" aria-hidden="true" /></span>
        }
      </nav>

      <CalendarBackLink />
    </header>

    <div class="desktop-calendar">
      <div class="weekday-row" aria-hidden="true">
        {['一', '二', '三', '四', '五', '六', '日'].map(day => <span>{day}</span>)}
      </div>

      <section class="calendar-grid" aria-label={`${year} 年 ${month} 月`}>
        {
          calendarDays.map((calendarDay) => {
          if (!calendarDay) {
            return <div class="calendar-day calendar-day--empty" aria-hidden="true" />
          }

          const thumbnail = getThumbnailImage(calendarDay.thumbnail)
          const isSelected = calendarDay.dateKey === selectedDate
          const isToday = calendarDay.dateKey === today
          const dayStatusDescription = calendarDay.chinaCalendarDay
            ? getChinaCalendarDayDescription(calendarDay.chinaCalendarDay)
            : undefined

          if (calendarDay.moments.length === 0) {
            return (
              <div class:list={['calendar-day', { 'calendar-day--today': isToday }] }>
                <span class="calendar-day__number">{String(calendarDay.day).padStart(2, '0')}</span>
                {calendarDay.chinaCalendarDay && <CalendarDayStatus day={calendarDay.chinaCalendarDay} compact />}
              </div>
            )
          }

          return (
            <a
              href={getMomentPath(calendarDay.dateKey)}
              class:list={[
                'calendar-day calendar-day--active',
                {
                  'calendar-day--selected': isSelected,
                  'calendar-day--today': isToday,
                  'calendar-day--with-media': thumbnail,
                },
              ]}
              aria-current={isSelected ? 'date' : undefined}
              aria-label={`${calendarDay.dateKey}，${calendarDay.moments.length} 条记录${dayStatusDescription ? `，${dayStatusDescription}` : ''}`}
            >
              {thumbnail && (
                <Image
                  src={thumbnail}
                  alt=""
                  width={Math.min(thumbnail.width, 360)}
                  height={Math.round(Math.min(thumbnail.width, 360) * thumbnail.height / thumbnail.width)}
                  loading="lazy"
                />
              )}
              <span class="calendar-day__shade" />
              <span class="calendar-day__number">{String(calendarDay.day).padStart(2, '0')}</span>
              {calendarDay.chinaCalendarDay && <CalendarDayStatus day={calendarDay.chinaCalendarDay} compact />}
              {
                thumbnail
                  ? calendarDay.mediaCount > 1 && <span class="calendar-day__count">+{calendarDay.mediaCount - 1}</span>
                  : <span class="calendar-day__activity">• {calendarDay.moments.length}</span>
              }
            </a>
          )
          })
        }
      </section>
    </div>

    {
      !selectedDate && (
        <MobileAgenda days={activeCalendarDays} year={year} month={month} />
      )
    }
  </main>

  {
    selectedDate && selectedDateLabel && (
      <>
        <a class="drawer-scrim" href={closePath} aria-label="关闭当天详情" />
        <aside
          class="day-drawer"
          data-calendar-drawer
          data-close-path={closePath}
          data-previous-path={previousDate ? getMomentPath(previousDate) : undefined}
          data-next-path={nextDate ? getMomentPath(nextDate) : undefined}
          aria-label={`${selectedDateLabel}的记录`}
        >
          <header class="day-drawer__header">
            <h2>{selectedDateLabel}</h2>
            <a href={closePath} aria-label="返回本月">
              <span class="day-drawer__close-icon i-lucide-x" aria-hidden="true" />
              <span class="day-drawer__back-label"><span class="i-lucide-chevron-left" aria-hidden="true" />{month} 月</span>
            </a>
          </header>

          <div class="day-drawer__content">
            {
              selectedMoments.map(moment => <MomentEntry moment={moment} />)
            }
          </div>

          <nav class="day-drawer__navigation" aria-label="日期导航">
            {
              previousDate
                ? <a href={getMomentPath(previousDate)}><span class="i-lucide-chevron-left" aria-hidden="true" />{formatCompactDate(previousDate)}</a>
                : <span />
            }
            <a href={closePath}>本月</a>
            {
              nextDate
                ? <a href={getMomentPath(nextDate)}>{formatCompactDate(nextDate)}<span class="i-lucide-chevron-right" aria-hidden="true" /></a>
                : <span />
            }
          </nav>
        </aside>

      </>
    )
  }

  <dialog class="moment-lightbox" data-moment-lightbox aria-label="图片查看器">
    <button type="button" class="moment-lightbox__close" data-lightbox-close aria-label="关闭图片"><span class="i-lucide-x" aria-hidden="true" /></button>
    <button type="button" class="moment-lightbox__previous" data-lightbox-previous aria-label="上一张图片"><span class="i-lucide-chevron-left" aria-hidden="true" /></button>
    <img alt="" data-lightbox-image />
    <button type="button" class="moment-lightbox__next" data-lightbox-next aria-label="下一张图片"><span class="i-lucide-chevron-right" aria-hidden="true" /></button>
  </dialog>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client'

  let calendarController: AbortController | undefined

  function initializeCalendar() {
    calendarController?.abort()
    calendarController = new AbortController()
    const { signal } = calendarController
    const drawer = document.querySelector<HTMLElement>('[data-calendar-drawer]')

    document.documentElement.classList.toggle('calendar-drawer-open', Boolean(drawer))

    if (drawer) {
      window.addEventListener('keydown', (event) => {
        const lightbox = document.querySelector<HTMLDialogElement>('[data-moment-lightbox]')

        if (lightbox?.open || event.metaKey || event.ctrlKey || event.altKey) {
          return
        }

        if (event.key === 'Escape') {
          void navigate(drawer.dataset.closePath ?? '/calendar')
          return
        }

        const target = event.target
        const isInteractiveTarget = target instanceof HTMLElement
          && target.closest('a, button, input, select, textarea, video, [contenteditable="true"]')

        if (isInteractiveTarget) {
          return
        }

        if (event.key === 'ArrowLeft' && drawer.dataset.previousPath) {
          void navigate(drawer.dataset.previousPath)
        } else if (event.key === 'ArrowRight' && drawer.dataset.nextPath) {
          void navigate(drawer.dataset.nextPath)
        }
      }, { signal })
    }

    for (const indexButton of document.querySelectorAll<HTMLButtonElement>('[data-agenda-target]')) {
      indexButton.addEventListener('click', () => {
        const targetId = indexButton.dataset.agendaTarget

        if (targetId) {
          document.getElementById(targetId)?.scrollIntoView({ behavior: 'auto', block: 'start' })
        }
      }, { signal })
    }

    const lightbox = document.querySelector<HTMLDialogElement>('[data-moment-lightbox]')
    const lightboxImage = lightbox?.querySelector<HTMLImageElement>('[data-lightbox-image]')
    const lightboxItems = [...document.querySelectorAll<HTMLElement>('[data-lightbox-item]')]
    let lightboxIndex = 0

    function showLightboxItem(index: number) {
      if (!lightbox || !lightboxImage || lightboxItems.length === 0) {
        return
      }

      lightboxIndex = (index + lightboxItems.length) % lightboxItems.length
      const item = lightboxItems[lightboxIndex]

      if (!item) {
        return
      }

      lightboxImage.src = item.dataset.lightboxSrc ?? ''
      lightboxImage.alt = item.dataset.lightboxAlt ?? ''
    }

    for (const [index, item] of lightboxItems.entries()) {
      item.addEventListener('click', () => {
        showLightboxItem(index)
        lightbox?.showModal()
      }, { signal })
    }

    lightbox?.querySelector('[data-lightbox-close]')?.addEventListener('click', () => lightbox.close(), { signal })
    lightbox?.querySelector('[data-lightbox-previous]')?.addEventListener('click', () => showLightboxItem(lightboxIndex - 1), { signal })
    lightbox?.querySelector('[data-lightbox-next]')?.addEventListener('click', () => showLightboxItem(lightboxIndex + 1), { signal })
    lightbox?.addEventListener('click', event => {
      if (event.target === lightbox) {
        lightbox.close()
      }
    }, { signal })
    lightbox?.addEventListener('keydown', event => {
      if (event.key === 'ArrowLeft') {
        showLightboxItem(lightboxIndex - 1)
      } else if (event.key === 'ArrowRight') {
        showLightboxItem(lightboxIndex + 1)
      }
    }, { signal })
  }

  document.addEventListener('astro:page-load', initializeCalendar)
  initializeCalendar()
</script>

<style>
  :global(:root) {
    --calendar-drawer-width: 27rem;
  }

  .calendar-page {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    height: calc(100dvh - 4rem);
    margin: 0 auto;
    max-width: 60rem;
    width: 100%;
  }

  .desktop-calendar {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-height: 0;
  }

  .calendar-toolbar {
    align-items: center;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    margin-bottom: 1rem;
  }

  .calendar-toolbar > :global(.calendar-back-link) {
    grid-column: 3;
    justify-self: end;
  }

  .calendar-toolbar > :global(.calendar-mode-switch) {
    grid-column: 1;
    justify-self: start;
  }

  .month-navigation {
    align-items: center;
    display: flex;
    gap: 1.25rem;
    grid-column: 2;
    justify-content: center;
  }

  .month-navigation__arrow {
    align-items: center;
    color: var(--color-tx-2);
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    text-decoration: none;
    width: 2rem;
  }

  .month-navigation__arrow--disabled {
    color: var(--color-tx-3);
    opacity: 0.35;
  }

  .month-picker {
    position: relative;
  }

  .month-picker summary {
    align-items: center;
    cursor: pointer;
    display: flex;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    gap: 0.5rem;
    list-style: none;
    padding: 0.375rem 0.5rem;
  }

  .month-picker summary::-webkit-details-marker {
    display: none;
  }

  .month-picker__panel {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    box-shadow: 0 1rem 3rem rgb(0 0 0 / 0.08);
    left: 50%;
    max-height: min(32rem, 70vh);
    overflow-y: auto;
    padding: 1rem;
    position: absolute;
    top: calc(100% + 0.5rem);
    transform: translateX(-50%);
    width: min(22rem, calc(100vw - 2rem));
    z-index: 20;
  }

  .month-picker__panel section + section {
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .month-picker__panel h2 {
    color: var(--color-tx-2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 0.625rem;
  }

  .month-picker__panel section > div {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.25rem;
  }

  .month-picker__panel a {
    align-items: center;
    color: var(--color-tx-3);
    display: flex;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    height: 2rem;
    justify-content: center;
    text-decoration: none;
  }

  .month-picker__panel a.has-content {
    color: var(--color-tx);
  }

  .month-picker__panel a.is-active {
    background: var(--color-inline);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }

  .weekday-row,
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .weekday-row {
    color: var(--color-tx-3);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    margin-bottom: 0.625rem;
    text-align: center;
  }

  .weekday-row span:nth-last-child(-n + 2) {
    color: var(--color-tx-2);
  }

  .calendar-grid {
    border-left: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
    grid-template-rows: repeat(var(--calendar-weeks), minmax(0, 1fr));
    min-height: 0;
  }

  .calendar-day {
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    color: var(--color-tx-2);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    min-height: 0;
    min-width: 0;
    overflow: hidden;
    padding: 0.75rem;
    position: relative;
    text-decoration: none;
  }

  .calendar-day--active {
    color: var(--color-tx);
  }

  .calendar-day--active:focus-visible {
    outline: 2px solid var(--color-tx);
    outline-offset: -3px;
  }

  .calendar-day--selected {
    box-shadow: inset 0 0 0 2px var(--color-tx);
    z-index: 2;
  }

  .calendar-day--today .calendar-day__number {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.25rem;
  }

  .calendar-day :global(img) {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    transition: transform 180ms ease;
    width: 100%;
  }

  .calendar-day--with-media:hover :global(img) {
    transform: scale(1.025);
  }

  .calendar-day__shade {
    background: linear-gradient(to bottom, rgb(0 0 0 / 0.2), transparent 45%, rgb(0 0 0 / 0.28));
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
  }

  .calendar-day--with-media .calendar-day__shade {
    opacity: 1;
  }

  .calendar-day__number,
  .calendar-day__activity,
  .calendar-day__count,
  .calendar-day :global(.calendar-day-status--compact) {
    position: relative;
    z-index: 1;
  }

  .calendar-day :global(.calendar-day-status--compact) {
    bottom: 0.625rem;
    left: 0.625rem;
    max-width: calc(100% - 1.25rem);
    position: absolute;
  }

  .calendar-day:has(.calendar-day__count) :global(.calendar-day-status--compact) {
    max-width: calc(100% - 3rem);
  }

  .calendar-day--with-media .calendar-day__number,
  .calendar-day--with-media .calendar-day__count,
  .calendar-day--with-media :global(.calendar-day-status--compact) {
    color: white;
    text-shadow: 0 1px 0.25rem rgb(0 0 0 / 0.45);
  }

  .calendar-day--with-media :global(.calendar-day-status--compact) {
    background: rgb(17 17 16 / 0.58);
    border-radius: 0.1875rem;
    padding: 0.125rem 0.25rem;
    text-shadow: none;
  }

  .calendar-day__activity {
    color: var(--color-tx-3);
    display: block;
    font-size: 0.6875rem;
    margin-top: 0.375rem;
  }

  .calendar-day__count {
    bottom: 0.625rem;
    font-size: 0.6875rem;
    right: 0.625rem;
    position: absolute;
  }

  .day-drawer__back-label,
  .day-drawer__navigation {
    display: none;
  }

  .drawer-scrim {
    display: none;
  }

  .day-drawer {
    background: var(--color-bg);
    border-left: 1px solid var(--color-border);
    bottom: 0;
    box-shadow: -1rem 0 3rem rgb(0 0 0 / 0.07);
    display: flex;
    flex-direction: column;
    position: fixed;
    right: 0;
    top: 0;
    width: min(var(--calendar-drawer-width), 100vw);
    z-index: 40;
  }

  .day-drawer__header {
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    padding: 1.5rem;
  }

  .day-drawer__header h2 {
    font-size: 1rem;
    font-weight: 600;
  }

  .day-drawer__header a {
    align-items: center;
    color: var(--color-tx-2);
    display: flex;
    height: 2rem;
    justify-content: center;
    text-decoration: none;
    width: 2rem;
  }

  .day-drawer__content {
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0 1.5rem 3rem;
  }

  .moment-lightbox {
    background: transparent;
    border: 0;
    height: 100%;
    margin: auto;
    max-height: none;
    max-width: none;
    padding: 3rem;
    width: 100%;
  }

  .moment-lightbox::backdrop {
    background: rgb(17 17 16 / 0.92);
  }

  .moment-lightbox[open] {
    align-items: center;
    display: flex;
    justify-content: center;
  }

  .moment-lightbox img {
    max-height: calc(100vh - 6rem);
    max-width: calc(100vw - 10rem);
    object-fit: contain;
  }

  .moment-lightbox button {
    align-items: center;
    background: rgb(255 255 255 / 0.08);
    border: 0;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    display: flex;
    height: 2.5rem;
    justify-content: center;
    position: fixed;
    width: 2.5rem;
  }

  .moment-lightbox__close {
    right: 1.25rem;
    top: 1.25rem;
  }

  .moment-lightbox__previous {
    left: 1.25rem;
    top: calc(50% - 1.25rem);
  }

  .moment-lightbox__next {
    right: 1.25rem;
    top: calc(50% - 1.25rem);
  }

  @media (min-width: 56.0625rem) {
    :global(html.calendar-drawer-open) {
      overflow: hidden;
    }

    :global(body:has(.day-drawer)) {
      padding-right: calc(var(--calendar-drawer-width) + 1rem);
