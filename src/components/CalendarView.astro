---
import CalendarBackLink from '@/components/CalendarBackLink.astro'
import CalendarDayStatus from '@/components/CalendarDayStatus.astro'
import CalendarModeSwitch from '@/components/CalendarModeSwitch.astro'
import MobileAgenda from '@/components/MobileAgenda.astro'
import MomentEntry from '@/components/MomentEntry.astro'
import {
  getChinaCalendarDay,
  getChinaCalendarDayDescription,
  type ChinaCalendarDay,
} from '@/china-calendar'
import Layout from '@/layouts/Layout.astro'
import {
  getActiveDateKeys,
  getArchiveMonthKeys,
  getMomentDateKey,
  getMomentPath,
  getMoments,
  getMonthPath,
  type Moment,
  type ResolvedMomentMedia,
} from '@/moments'
import { SITE_TITLE } from '@/consts'
import { Image } from 'astro:assets'

interface Props {
  month: number
  selectedDate?: string
  year: number
}

type CalendarDay = {
  chinaCalendarDay: ChinaCalendarDay | undefined
  dateKey: string
  day: number
  mediaCount: number
  moments: Moment[]
  thumbnail: ResolvedMomentMedia | undefined
}

const { month, selectedDate, year } = Astro.props
const moments = await getMoments()
const activeDateKeys = getActiveDateKeys(moments)
const monthKeys = getArchiveMonthKeys(moments)
const monthKey = `${year}-${String(month).padStart(2, '0')}`
const currentMonthIndex = monthKeys.indexOf(monthKey)
const previousMonth = currentMonthIndex > 0 ? monthKeys[currentMonthIndex - 1] : undefined
const nextMonth = currentMonthIndex >= 0 && currentMonthIndex < monthKeys.length - 1
  ? monthKeys[currentMonthIndex + 1]
  : undefined
const momentsByDate = Map.groupBy(moments, moment => moment.dateKey)
const daysInMonth = new Date(Date.UTC(year, month, 0)).getUTCDate()
const firstWeekday = (new Date(Date.UTC(year, month - 1, 1)).getUTCDay() + 6) % 7
const calendarDays: Array<CalendarDay | undefined> = Array.from({ length: firstWeekday })

for (let day = 1; day <= daysInMonth; day += 1) {
  const dateKey = `${monthKey}-${String(day).padStart(2, '0')}`
  const dayMoments = momentsByDate.get(dateKey) ?? []
  const allMedia = dayMoments.flatMap(moment => moment.media)
  const thumbnail = allMedia.find(item => item.type === 'image' || item.poster)

  calendarDays.push({
    chinaCalendarDay: getChinaCalendarDay(dateKey),
    dateKey,
    day,
    mediaCount: allMedia.length,
    moments: dayMoments,
    thumbnail,
  })
}

while (calendarDays.length % 7 !== 0) {
  calendarDays.push(undefined)
}

const activeCalendarDays = calendarDays.filter(
  (day): day is CalendarDay => Boolean(day?.moments.length),
)
const today = getMomentDateKey(new Date())
const selectedMoments = selectedDate ? momentsByDate.get(selectedDate) ?? [] : []
const selectedDateIndex = selectedDate ? activeDateKeys.indexOf(selectedDate) : -1
const previousDate = selectedDateIndex > 0 ? activeDateKeys[selectedDateIndex - 1] : undefined
const nextDate = selectedDateIndex >= 0 && selectedDateIndex < activeDateKeys.length - 1
  ? activeDateKeys[selectedDateIndex + 1]
  : undefined
const groupedMonths = Map.groupBy(monthKeys, key => key.slice(0, 4))
const activeMonthKeys = new Set(activeDateKeys.map(key => key.slice(0, 7)))
const description = '一些零碎记录，按发生的日期归档。'
const selectedDateLabel = selectedDate ? formatSelectedDate(selectedDate) : undefined
const title = selectedDateLabel
  ? `${selectedDateLabel} · 日历 | ${SITE_TITLE}`
  : `${year} 年 ${month} 月 · 日历 | ${SITE_TITLE}`
const closePath = getMonthPath(monthKey)

function formatSelectedDate(dateKey: string) {
  const { dateDay, dateMonth, dateValue } = parseCalendarDate(dateKey)
  const weekday = new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Singapore',
    weekday: 'long',
  }).format(dateValue)

  return `${dateMonth} 月 ${dateDay} 日 · ${weekday}`
}

function formatCompactDate(dateKey: string) {
  return `${Number.parseInt(dateKey.slice(5, 7), 10)}/${Number.parseInt(dateKey.slice(8, 10), 10)}`
}

function parseCalendarDate(dateKey: string) {
  const dateYear = Number.parseInt(dateKey.slice(0, 4), 10)
  const dateMonth = Number.parseInt(dateKey.slice(5, 7), 10)
  const dateDay = Number.parseInt(dateKey.slice(8, 10), 10)

  return {
    dateDay,
    dateMonth,
    dateValue: new Date(Date.UTC(dateYear, dateMonth - 1, dateDay)),
  }
}

function getThumbnailImage(media?: ResolvedMomentMedia) {
  if (!media) {
    return undefined
  }

  return media.type === 'image' ? media.src : media.poster
}
---

<Layout title={title} description={description}>
  <main
    class:list={[
      'calendar-page mx-auto grid h-[calc(100dvh-4rem)] w-full max-w-[60rem] grid-rows-[auto_minmax(0,1fr)] max-[56rem]:block max-[56rem]:h-auto max-[56rem]:max-w-[42rem]',
      {
        'calendar-page--with-drawer max-[56rem]:hidden min-[56.0625rem]:overflow-y-auto min-[56.0625rem]:overscroll-contain': selectedDate,
      },
    ]}
    style={`--calendar-weeks: ${calendarDays.length / 7}`}
  >
    <header class="calendar-toolbar mb-4 grid grid-cols-[1fr_auto_1fr] items-center max-[56rem]:grid-cols-[1fr_auto] max-[56rem]:gap-2">
      <CalendarModeSwitch class="col-start-1 justify-self-start max-[56rem]:row-start-1" mode="calendar" />

      <nav class="month-navigation col-start-2 flex items-center justify-center gap-5 max-[56rem]:col-span-full max-[56rem]:col-start-1 max-[56rem]:row-start-2 max-[40rem]:gap-2" aria-label="月份导航">
        {
          previousMonth
            ? <a class="month-navigation__arrow inline-flex size-8 items-center justify-center text-tx-2 no-underline max-[56rem]:size-11" href={getMonthPath(previousMonth)} aria-label="上一个月"><span class="i-lucide-chevron-left" aria-hidden="true" /></a>
            : <span class="month-navigation__arrow month-navigation__arrow--disabled inline-flex size-8 items-center justify-center text-tx-3 opacity-35 max-[56rem]:size-11"><span class="i-lucide-chevron-left" aria-hidden="true" /></span>
        }

        <details class="month-picker relative">
          <summary class="flex cursor-pointer list-none items-center gap-2 px-2 py-1.5 font-mono max-[56rem]:min-h-11 [&::-webkit-details-marker]:hidden">{year} 年 {month} 月 <span class="i-lucide-chevron-down" aria-hidden="true" /></summary>
          <div class="month-picker__panel absolute top-[calc(100%+0.5rem)] left-1/2 z-20 max-h-[min(32rem,70vh)] w-[min(22rem,calc(100vw-2rem))] -translate-x-1/2 overflow-y-auto border border-border bg-bg p-4 shadow-[0_1rem_3rem_rgb(0_0_0/0.08)]">
            {
              [...groupedMonths].map(([pickerYear, pickerMonths]) => (
                <section class="[&+&]:mt-4 [&+&]:border-t [&+&]:border-border [&+&]:pt-4">
                  <h2 class="mb-2.5 font-mono text-[0.8125rem] font-medium text-tx-2">{pickerYear}</h2>
                  <div class="grid grid-cols-6 gap-1">
                    {pickerMonths.map(key => {
                      const pickerMonth = Number.parseInt(key.slice(5), 10)
                      return (
                        <a
                          href={getMonthPath(key)}
                          class:list={[
                            'flex h-8 items-center justify-center font-mono no-underline',
                            key === monthKey && 'is-active bg-inline shadow-[inset_0_0_0_1px_var(--color-border)]',
                            activeMonthKeys.has(key) ? 'has-content text-tx' : 'text-tx-3',
                          ]}
                        >
                          {pickerMonth}
                        </a>
                      )
                    })}
                  </div>
                </section>
              ))
            }
          </div>
        </details>

        {
          nextMonth
            ? <a class="month-navigation__arrow inline-flex size-8 items-center justify-center text-tx-2 no-underline max-[56rem]:size-11" href={getMonthPath(nextMonth)} aria-label="下一个月"><span class="i-lucide-chevron-right" aria-hidden="true" /></a>
            : <span class="month-navigation__arrow month-navigation__arrow--disabled inline-flex size-8 items-center justify-center text-tx-3 opacity-35 max-[56rem]:size-11"><span class="i-lucide-chevron-right" aria-hidden="true" /></span>
        }
      </nav>

      <CalendarBackLink class="col-start-3 justify-self-end max-[56rem]:col-start-2 max-[56rem]:row-start-1" />
    </header>

    <div class="desktop-calendar grid min-h-0 content-start grid-rows-[auto_auto] max-[56rem]:hidden">
      <div class="weekday-row mb-2.5 grid grid-cols-7 text-center font-mono text-xs text-tx-3 [&_span:nth-last-child(-n+2)]:text-tx-2" aria-hidden="true">
        {['一', '二', '三', '四', '五', '六', '日'].map(day => <span>{day}</span>)}
      </div>

      <section class="calendar-grid grid min-h-0 grid-cols-7 grid-rows-[repeat(var(--calendar-weeks),minmax(0,1fr))] border-t border-l border-border [aspect-ratio:7/var(--calendar-weeks)]" aria-label={`${year} 年 ${month} 月`}>
        {
          calendarDays.map((calendarDay) => {
          if (!calendarDay) {
            return <div class="calendar-day calendar-day--empty relative min-h-0 min-w-0 overflow-hidden border-r border-b border-border p-3 font-mono text-tx-2" aria-hidden="true" />
          }

          const thumbnail = getThumbnailImage(calendarDay.thumbnail)
          const isSelected = calendarDay.dateKey === selectedDate
          const isToday = calendarDay.dateKey === today
          const dayStatusDescription = calendarDay.chinaCalendarDay
            ? getChinaCalendarDayDescription(calendarDay.chinaCalendarDay)
            : undefined

          if (calendarDay.moments.length === 0) {
            return (
              <div class:list={['calendar-day relative min-h-0 min-w-0 overflow-hidden border-r border-b border-border p-3 font-mono text-tx-2', { 'calendar-day--today': isToday }] }>
                <span class:list={['calendar-day__number relative z-[1]', { 'underline decoration-2 underline-offset-4': isToday }]}>{String(calendarDay.day).padStart(2, '0')}</span>
                {calendarDay.chinaCalendarDay && (
                  <CalendarDayStatus
                    class="absolute bottom-2.5 left-2.5 z-[1] max-w-[calc(100%-1.25rem)]"
                    day={calendarDay.chinaCalendarDay}
                    compact
                  />
                )}
              </div>
            )
          }

          return (
            <a
              href={getMomentPath(calendarDay.dateKey)}
              class:list={[
                'calendar-day calendar-day--active group relative min-h-0 min-w-0 overflow-hidden border-r border-b border-border p-3 font-mono text-tx no-underline focus-visible:outline-2 focus-visible:-outline-offset-3 focus-visible:outline-tx',
                {
                  'calendar-day--selected z-[2] shadow-[inset_0_0_0_2px_var(--color-tx)]': isSelected,
                  'calendar-day--today': isToday,
                  'calendar-day--with-media': thumbnail,
                },
              ]}
              aria-current={isSelected ? 'date' : undefined}
              aria-label={`${calendarDay.dateKey}，${calendarDay.moments.length} 条记录${dayStatusDescription ? `，${dayStatusDescription}` : ''}`}
            >
              {thumbnail && (
                <Image
                  src={thumbnail}
                  alt=""
                  width={Math.min(thumbnail.width, 360)}
                  height={Math.round(Math.min(thumbnail.width, 360) * thumbnail.height / thumbnail.width)}
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-[180ms] ease-in-out group-hover:scale-[1.025] motion-reduce:transition-none"
                />
              )}
              <span class:list={[
                'calendar-day__shade pointer-events-none absolute inset-0 bg-[linear-gradient(to_bottom,rgb(0_0_0/0.2),transparent_45%,rgb(0_0_0/0.28))]',
                thumbnail ? 'opacity-100' : 'opacity-0',
              ]}
              />
              <span class:list={[
                'calendar-day__number relative z-[1]',
                {
                  'underline decoration-2 underline-offset-4': isToday,
                  'text-white [text-shadow:0_1px_0.25rem_rgb(0_0_0/0.45)]': thumbnail,
                },
              ]}
              >
                {String(calendarDay.day).padStart(2, '0')}
              </span>
              {calendarDay.chinaCalendarDay && (
                <CalendarDayStatus
                  class:list={[
                    'absolute bottom-2.5 left-2.5 z-[1]',
                    calendarDay.mediaCount > 1 ? 'max-w-[calc(100%-3rem)]' : 'max-w-[calc(100%-1.25rem)]',
                    {
                      'rounded-[0.1875rem] bg-[rgb(17_17_16/0.58)] px-1 py-0.5 !text-white [text-shadow:none]': thumbnail,
                    },
                  ]}
                  day={calendarDay.chinaCalendarDay}
                  compact
                />
              )}
              {
                thumbnail
                  ? calendarDay.mediaCount > 1 && <span class="calendar-day__count absolute right-2.5 bottom-2.5 z-[1] text-[0.6875rem] text-white [text-shadow:0_1px_0.25rem_rgb(0_0_0/0.45)]">+{calendarDay.mediaCount - 1}</span>
                  : <span class="calendar-day__activity relative z-[1] mt-1.5 block text-[0.6875rem] text-tx-3">• {calendarDay.moments.length}</span>
              }
            </a>
          )
          })
        }
      </section>
    </div>

    {
      !selectedDate && (
        <MobileAgenda days={activeCalendarDays} year={year} month={month} />
      )
    }
  </main>

  {
    selectedDate && selectedDateLabel && (
      <>
        <a class="drawer-scrim hidden" href={closePath} aria-label="关闭当天详情" />
        <aside
          class="day-drawer fixed inset-y-0 right-0 z-40 flex w-[min(var(--calendar-drawer-width),100vw)] flex-col border-l border-border bg-bg shadow-[-1rem_0_3rem_rgb(0_0_0/0.07)] max-[56rem]:static max-[56rem]:mx-auto max-[56rem]:grid max-[56rem]:min-h-[calc(100dvh-2rem)] max-[56rem]:w-full max-[56rem]:max-w-[42rem] max-[56rem]:grid-rows-[auto_1fr_auto] max-[56rem]:border-0 max-[56rem]:shadow-none"
          data-calendar-drawer
          data-close-path={closePath}
          data-previous-path={previousDate ? getMomentPath(previousDate) : undefined}
          data-next-path={nextDate ? getMomentPath(nextDate) : undefined}
          aria-label={`${selectedDateLabel}的记录`}
        >
          <header class="day-drawer__header flex items-center justify-between border-b border-border p-6 max-[56rem]:sticky max-[56rem]:top-0 max-[56rem]:z-10 max-[56rem]:grid max-[56rem]:grid-cols-[1fr_auto_1fr] max-[56rem]:bg-bg max-[56rem]:px-0 max-[56rem]:py-3">
            <h2 class="text-base font-semibold max-[56rem]:col-start-2">{selectedDateLabel}</h2>
            <a class="flex size-8 items-center justify-center text-tx-2 no-underline max-[56rem]:col-start-1 max-[56rem]:row-start-1 max-[56rem]:h-11 max-[56rem]:w-auto max-[56rem]:justify-self-start" href={closePath} aria-label="返回本月">
              <span class="day-drawer__close-icon i-lucide-x max-[56rem]:hidden" aria-hidden="true" />
              <span class="day-drawer__back-label hidden items-center gap-1 text-sm max-[56rem]:flex"><span class="i-lucide-chevron-left" aria-hidden="true" />{month} 月</span>
            </a>
          </header>

          <div class="day-drawer__content overflow-y-auto overscroll-contain px-6 pb-12 max-[56rem]:overflow-visible max-[56rem]:p-0">
            {
              selectedMoments.map(moment => <MomentEntry moment={moment} />)
            }
          </div>

          <nav class="day-drawer__navigation sticky bottom-0 hidden grid-cols-3 border-t border-border bg-bg py-3.5 max-[56rem]:grid [&_a]:flex [&_a]:min-h-11 [&_a]:items-center [&_a]:gap-1 [&_a]:font-mono [&_a]:text-xs [&_a]:text-tx-2 [&_a]:no-underline [&>:first-child]:justify-self-start [&>:last-child]:justify-self-end [&>:nth-child(2)]:justify-self-center" aria-label="日期导航">
            {
              previousDate
                ? <a href={getMomentPath(previousDate)}><span class="i-lucide-chevron-left" aria-hidden="true" />{formatCompactDate(previousDate)}</a>
                : <span />
            }
            <a href={closePath}>本月</a>
            {
              nextDate
                ? <a href={getMomentPath(nextDate)}>{formatCompactDate(nextDate)}<span class="i-lucide-chevron-right" aria-hidden="true" /></a>
                : <span />
            }
          </nav>
        </aside>

      </>
    )
  }

  <dialog class="moment-lightbox m-auto h-full max-h-none w-full max-w-none border-0 bg-transparent p-12 backdrop:bg-[rgb(17_17_16/0.92)] [&[open]]:flex [&[open]]:items-center [&[open]]:justify-center max-[40rem]:px-4" data-moment-lightbox aria-label="图片查看器">
    <button type="button" class="moment-lightbox__close fixed top-5 right-5 flex size-10 cursor-pointer items-center justify-center rounded-full border-0 bg-[rgb(255_255_255/0.08)] text-white" data-lightbox-close aria-label="关闭图片"><span class="i-lucide-x" aria-hidden="true" /></button>
    <button type="button" class="moment-lightbox__previous fixed top-[calc(50%-1.25rem)] left-5 flex size-10 cursor-pointer items-center justify-center rounded-full border-0 bg-[rgb(255_255_255/0.08)] text-white max-[40rem]:top-auto max-[40rem]:bottom-4" data-lightbox-previous aria-label="上一张图片"><span class="i-lucide-chevron-left" aria-hidden="true" /></button>
    <img class="max-h-[calc(100vh-6rem)] max-w-[calc(100vw-10rem)] object-contain max-[40rem]:max-w-[calc(100vw-2rem)]" alt="" data-lightbox-image />
    <button type="button" class="moment-lightbox__next fixed top-[calc(50%-1.25rem)] right-5 flex size-10 cursor-pointer items-center justify-center rounded-full border-0 bg-[rgb(255_255_255/0.08)] text-white max-[40rem]:top-auto max-[40rem]:bottom-4" data-lightbox-next aria-label="下一张图片"><span class="i-lucide-chevron-right" aria-hidden="true" /></button>
  </dialog>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client'

  let calendarController: AbortController | undefined

  function initializeCalendar() {
    calendarController?.abort()
    calendarController = new AbortController()
    const { signal } = calendarController
    const drawer = document.querySelector<HTMLElement>('[data-calendar-drawer]')

    document.documentElement.classList.toggle('calendar-drawer-open', Boolean(drawer))

    if (drawer) {
      window.addEventListener('keydown', (event) => {
        const lightbox = document.querySelector<HTMLDialogElement>('[data-moment-lightbox]')

        if (lightbox?.open || event.metaKey || event.ctrlKey || event.altKey) {
          return
        }

        if (event.key === 'Escape') {
          void navigate(drawer.dataset.closePath ?? '/calendar')
          return
        }

        const target = event.target
        const isInteractiveTarget = target instanceof HTMLElement
          && target.closest('a, button, input, select, textarea, video, [contenteditable="true"]')

        if (isInteractiveTarget) {
          return
        }

        if (event.key === 'ArrowLeft' && drawer.dataset.previousPath) {
          void navigate(drawer.dataset.previousPath)
        } else if (event.key === 'ArrowRight' && drawer.dataset.nextPath) {
          void navigate(drawer.dataset.nextPath)
        }
      }, { signal })
    }

    for (const indexButton of document.querySelectorAll<HTMLButtonElement>('[data-agenda-target]')) {
      indexButton.addEventListener('click', () => {
        const targetId = indexButton.dataset.agendaTarget

        if (targetId) {
          document.getElementById(targetId)?.scrollIntoView({ behavior: 'auto', block: 'start' })
        }
      }, { signal })
    }

    const lightbox = document.querySelector<HTMLDialogElement>('[data-moment-lightbox]')
    const lightboxImage = lightbox?.querySelector<HTMLImageElement>('[data-lightbox-image]')
    const lightboxItems = [...document.querySelectorAll<HTMLElement>('[data-lightbox-item]')]
    let lightboxIndex = 0

    function showLightboxItem(index: number) {
      if (!lightbox || !lightboxImage || lightboxItems.length === 0) {
        return
      }

      lightboxIndex = (index + lightboxItems.length) % lightboxItems.length
      const item = lightboxItems[lightboxIndex]

      if (!item) {
        return
      }

      lightboxImage.src = item.dataset.lightboxSrc ?? ''
      lightboxImage.alt = item.dataset.lightboxAlt ?? ''
    }

    for (const [index, item] of lightboxItems.entries()) {
      item.addEventListener('click', () => {
        showLightboxItem(index)
        lightbox?.showModal()
      }, { signal })
    }

    lightbox?.querySelector('[data-lightbox-close]')?.addEventListener('click', () => lightbox.close(), { signal })
    lightbox?.querySelector('[data-lightbox-previous]')?.addEventListener('click', () => showLightboxItem(lightboxIndex - 1), { signal })
    lightbox?.querySelector('[data-lightbox-next]')?.addEventListener('click', () => showLightboxItem(lightboxIndex + 1), { signal })
    lightbox?.addEventListener('click', event => {
      if (event.target === lightbox) {
        lightbox.close()
      }
    }, { signal })
    lightbox?.addEventListener('keydown', event => {
      if (event.key === 'ArrowLeft') {
        showLightboxItem(lightboxIndex - 1)
      } else if (event.key === 'ArrowRight') {
        showLightboxItem(lightboxIndex + 1)
      }
    }, { signal })
  }

  document.addEventListener('astro:page-load', initializeCalendar)
  initializeCalendar()
</script>
