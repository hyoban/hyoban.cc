---
import CalendarBackLink from '@/components/CalendarBackLink.astro'
import CalendarModeSwitch from '@/components/CalendarModeSwitch.astro'
import MomentEntry from '@/components/MomentEntry.astro'
import Layout from '@/layouts/Layout.astro'
import { getYearColor } from '@/map-locations'
import {
  getMappedLocationGroups,
  getMomentPath,
  getMoments,
} from '@/moments'
import { SITE_TITLE } from '@/consts'

const moments = await getMoments()
const locationGroups = getMappedLocationGroups(moments)
const years = [...new Set(locationGroups.map(group => group.latestYear))].sort((a, b) => a - b)
const mapboxToken = import.meta.env.VITE_MAPBOX_TOKEN ?? ''
const title = `地图 · 日历 | ${SITE_TITLE}`
const description = '按地点浏览 Calendar 中记录的 Moment。'
const markerData = locationGroups.map(group => ({
  color: getYearColor(group.latestYear),
  count: group.moments.length,
  id: group.id,
  latestYear: group.latestYear,
  latitude: group.location.latitude,
  longitude: group.location.longitude,
  name: group.location.name,
}))
const markerDataJson = JSON.stringify(markerData).replaceAll('<', '\\u003c')

function formatDate(dateKey: string) {
  const date = new Date(`${dateKey}T00:00:00Z`)
  return new Intl.DateTimeFormat('zh-CN', {
    day: 'numeric',
    month: 'long',
    timeZone: 'UTC',
    weekday: 'short',
    year: 'numeric',
  }).format(date)
}
---

<Layout title={title} description={description}>
  <main class="calendar-map-page relative isolate h-dvh w-full overflow-hidden bg-bg" data-calendar-map data-mapbox-token={mapboxToken} transition:persist="calendar-map">
    <div class="calendar-map-canvas absolute inset-0" data-calendar-map-canvas role="region" aria-label="Calendar 地点地图" />

    <header class="calendar-map-toolbar pointer-events-none absolute inset-x-4 top-4 z-[5] grid grid-cols-[1fr_auto_1fr] items-center gap-4 [&>*]:pointer-events-auto">
      <CalendarModeSwitch class="justify-self-start" mode="map" />
      <p class="col-start-2 flex min-h-[2.375rem] items-center rounded-full border border-[color-mix(in_srgb,var(--color-border)_82%,transparent)] bg-[color-mix(in_srgb,var(--color-bg)_82%,transparent)] px-3.5 font-mono text-[0.8125rem] backdrop-blur-[1rem] max-[48rem]:hidden">全部地点</p>
      <CalendarBackLink class="col-start-3 justify-self-end" />
    </header>

    <ol class="calendar-map-legend absolute bottom-10 left-1/2 z-[4] flex -translate-x-1/2 list-none items-center gap-3 rounded-full border border-[color-mix(in_srgb,var(--color-border)_82%,transparent)] bg-[color-mix(in_srgb,var(--color-bg)_82%,transparent)] px-3.5 py-2.5 font-mono text-xs shadow-[0_0.5rem_2rem_rgb(0_0_0/0.08)] max-[48rem]:bottom-[calc(1rem+env(safe-area-inset-bottom))]" aria-label="地点最近记录年份">
      {
        years.map(year => (
          <li class="flex items-center gap-[0.35rem]">
            <span class="block size-2.5 rounded-full border border-white/90 bg-[var(--year-color)] shadow-[0_0_0_1px_rgb(0_0_0/0.12)]" style={`--year-color: ${getYearColor(year)}`} aria-hidden="true" />
            {year}
          </li>
        ))
      }
    </ol>

    <p class="calendar-map-loading absolute left-1/2 top-1/2 z-[3] -translate-1/2 rounded-full border border-border bg-[color-mix(in_srgb,var(--color-bg)_88%,transparent)] px-3.5 py-2.5 [&[hidden]]:hidden" data-calendar-map-loading>正在加载地图…</p>

    <section class="calendar-map-fallback absolute left-1/2 top-1/2 z-[6] max-h-[min(36rem,calc(100dvh-8rem))] w-[min(28rem,calc(100vw-2rem))] -translate-1/2 overflow-y-auto border border-border bg-[color-mix(in_srgb,var(--color-bg)_94%,transparent)] p-5 shadow-[0_1rem_4rem_rgb(0_0_0/0.12)] [&[hidden]]:hidden" data-calendar-map-fallback aria-live="polite" hidden>
      <p class="mb-4 leading-[1.6] text-tx-2" data-calendar-map-fallback-message>地图暂时无法加载，仍可通过地点列表浏览记录。</p>
      <div class="grid grid-cols-2 gap-1">
        {
          locationGroups.map(group => (
            <button class="grid min-h-11 cursor-pointer grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-2 border-0 bg-transparent px-2 text-left text-tx hover:bg-inline focus-visible:bg-inline" type="button" data-map-location-id={group.id}>
              <span class="block size-2.5 rounded-full border border-white/90 bg-[var(--year-color)] shadow-[0_0_0_1px_rgb(0_0_0/0.12)]" style={`--year-color: ${getYearColor(group.latestYear)}`} aria-hidden="true" />
              <strong class="truncate font-medium">{group.location.name}</strong>
              <small class="text-tx-3">{group.moments.length} 条</small>
            </button>
          ))
        }
      </div>
    </section>

    <aside class="calendar-map-drawer absolute inset-y-4 right-4 z-10 grid w-[min(28rem,calc(100vw-2rem))] min-w-0 grid-rows-[auto_minmax(0,1fr)] border border-border bg-bg shadow-[0_1.5rem_5rem_rgb(0_0_0/0.16)] max-[48rem]:inset-x-3 max-[48rem]:bottom-[calc(0.75rem+env(safe-area-inset-bottom))] max-[48rem]:top-auto max-[48rem]:h-[min(78dvh,42rem)] max-[48rem]:w-auto max-[48rem]:rounded-xl [&[hidden]]:hidden" data-calendar-map-drawer role="dialog" aria-labelledby="calendar-map-drawer-title" hidden>
      <header class="flex items-center justify-between border-b border-border px-5 py-4">
        <div class="min-w-0">
          <p class="mb-0.5 font-mono text-[0.6875rem] uppercase text-tx-3">地点</p>
          <h1 class="text-lg font-medium" id="calendar-map-drawer-title" data-calendar-map-drawer-title />
        </div>
        <button class="flex size-11 cursor-pointer items-center justify-center border-0 bg-transparent text-inherit" type="button" data-calendar-map-drawer-close aria-label="关闭地点详情">
          <span class="i-lucide-x" aria-hidden="true" />
        </button>
      </header>
      <div class="calendar-map-drawer__content min-w-0 overflow-y-auto overscroll-contain px-5 pb-4" data-calendar-map-drawer-content />
    </aside>

    {
      locationGroups.map(group => {
        const groupYears = [...new Set(group.moments.map(moment => Number.parseInt(moment.dateKey.slice(0, 4), 10)))]
          .sort((a, b) => b - a)

        return (
          <template data-calendar-map-template={group.id}>
            <div class="calendar-map-drawer__summary flex items-center gap-1.5 pt-4 pb-1 font-mono text-xs text-tx-3">
              <span>{group.moments.length} 条记录</span>
              <span aria-hidden="true">·</span>
              <span>{groupYears.map(year => `${year} 年`).join('、')}</span>
            </div>
            <div class="calendar-map-drawer__moments min-w-0">
              {group.moments.map(moment => (
                <section class="calendar-map-moment min-w-0 [&+&]:border-t [&+&]:border-border">
                  <a class="calendar-map-moment__date mt-5 inline-block font-mono text-xs text-tx-2 no-underline" href={getMomentPath(moment.dateKey)}>
                    {formatDate(moment.dateKey)}
                  </a>
                  <MomentEntry class="!pt-2.5" moment={moment} showLocation={false} />
                </section>
              ))}
            </div>
          </template>
        )
      })
    }

    <dialog class="calendar-map-lightbox m-0 h-dvh max-h-none w-screen max-w-none border-0 bg-black/88 p-16 backdrop:bg-transparent max-[48rem]:px-4 max-[48rem]:py-12" data-calendar-map-lightbox aria-label="图片查看器">
      <button type="button" class="calendar-map-lightbox__close fixed right-4 top-4 z-[1] flex size-11 cursor-pointer items-center justify-center border-0 bg-transparent text-white" data-map-lightbox-close aria-label="关闭图片">
        <span class="i-lucide-x" aria-hidden="true" />
      </button>
      <button type="button" class="calendar-map-lightbox__previous fixed left-2 top-1/2 z-[1] flex size-11 -translate-y-1/2 cursor-pointer items-center justify-center border-0 bg-transparent text-white max-[48rem]:bottom-4 max-[48rem]:top-auto max-[48rem]:translate-y-0" data-map-lightbox-previous aria-label="上一张图片">
        <span class="i-lucide-chevron-left" aria-hidden="true" />
      </button>
      <img class="size-full object-contain" alt="" data-map-lightbox-image />
      <button type="button" class="calendar-map-lightbox__next fixed right-2 top-1/2 z-[1] flex size-11 -translate-y-1/2 cursor-pointer items-center justify-center border-0 bg-transparent text-white max-[48rem]:bottom-4 max-[48rem]:top-auto max-[48rem]:translate-y-0" data-map-lightbox-next aria-label="下一张图片">
        <span class="i-lucide-chevron-right" aria-hidden="true" />
      </button>
    </dialog>

    <script is:inline type="application/json" data-calendar-map-locations set:html={markerDataJson} />
  </main>
</Layout>

<script>
  import '@/calendar-map-client'
</script>
