---
import CalendarDayStatus from '@/components/CalendarDayStatus.astro'
import MomentEntry from '@/components/MomentEntry.astro'
import type { ChinaCalendarDay } from '@/china-calendar'
import type { Moment } from '@/moments'

interface AgendaDay {
  chinaCalendarDay: ChinaCalendarDay | undefined
  dateKey: string
  day: number
  moments: Moment[]
}

interface Props {
  days: AgendaDay[]
  month: number
  year: number
}

const { days, month, year } = Astro.props
const agendaDays = days.toReversed()

function formatDate(dateKey: string) {
  const dateYear = Number.parseInt(dateKey.slice(0, 4), 10)
  const dateMonth = Number.parseInt(dateKey.slice(5, 7), 10)
  const dateDay = Number.parseInt(dateKey.slice(8, 10), 10)
  const weekday = new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Singapore',
    weekday: 'short',
  }).format(new Date(Date.UTC(dateYear, dateMonth - 1, dateDay)))

  return `${dateMonth} 月 ${dateDay} 日 · ${weekday}`
}
---

<section class="mobile-agenda hidden max-[56rem]:block" aria-label={`${year} 年 ${month} 月的全部记录`}>
  {
    days.length > 0
      ? (
          <>
            <nav class="mobile-agenda__index mt-3 flex gap-2 overflow-x-auto border-y border-border py-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="本月有记录的日期">
              {days.map(day => (
                <button
                  type="button"
                  class="flex h-11 min-w-11 flex-none cursor-pointer items-center justify-center border-0 bg-transparent p-0 font-mono text-tx-2"
                  data-agenda-target={`agenda-${day.dateKey}`}
                  aria-label={`定位到 ${formatDate(day.dateKey)}`}
                >
                  {String(day.day).padStart(2, '0')}
                </button>
              ))}
            </nav>

            <div class="mobile-agenda__days">
              {agendaDays.map(day => (
                <section class="mobile-agenda__day scroll-mt-3 [&+&]:border-t [&+&]:border-border" id={`agenda-${day.dateKey}`}>
                  <header class="flex items-baseline justify-between gap-3 pt-7">
                    <div class="mobile-agenda__date flex min-w-0 items-baseline gap-2.5">
                      <h2 class="text-lg font-medium">{formatDate(day.dateKey)}</h2>
                      {day.chinaCalendarDay && <CalendarDayStatus day={day.chinaCalendarDay} />}
                    </div>
                    <span class="mobile-agenda__count whitespace-nowrap font-mono text-xs text-tx-3">{day.moments.length} 条</span>
                  </header>
                  <div class="mobile-agenda__moments pb-1">
                    {day.moments.map(moment => <MomentEntry moment={moment} />)}
                  </div>
                </section>
              ))}
            </div>
          </>
        )
      : <p class="mobile-agenda__empty py-16 text-center text-tx-3">本月没有记录。</p>
  }
</section>
