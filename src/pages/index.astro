---
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { formatPostListDate, formatPostYear, getSortedPosts } from '@/utils'

const posts = await getSortedPosts()
const introLinkClass = 'text-tx underline hover:text-cy'
type Post = (typeof posts)[number]
const postsByYear: Array<{ year: string; posts: Post[] }> = []

for (const post of posts) {
  const year = formatPostYear(post.data.pubDate)
  const lastGroup = postsByYear[postsByYear.length - 1]

  if (lastGroup?.year === year) {
    lastGroup.posts.push(post)
  } else {
    postsByYear.push({ year, posts: [post] })
  }
}
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main class="container max-w-[65ch] mx-auto">
    <section class="mb-10 space-y-3">
      <h1>{SITE_TITLE}</h1>
      <p class="text-tx-2">{SITE_DESCRIPTION}</p>
      <p class="text-tx-2 leading-relaxed">
        我会在这里写一些关于工作、代码和生活的记录。你也可以在{' '}
        <a class={introLinkClass} href="https://x.com/hyoban_cc" target="_blank" rel="noopener noreferrer">X</a>、
        <a class={introLinkClass} href="https://bsky.app/profile/hyoban.cc" target="_blank" rel="noopener noreferrer">Bluesky</a>
        {' '}和 <a class={introLinkClass} href="https://t.me/hyoban" target="_blank" rel="noopener noreferrer">Telegram</a> 找到我；旅行相关的内容会放在{' '}
        <a class={introLinkClass} href="https://t.me/s/hyoban_travel" target="_blank" rel="noopener noreferrer">Telegram 旅行频道</a>
        {' '}和 <a class={introLinkClass} href="https://photos.hyoban.cc/" target="_blank" rel="noopener noreferrer">Photos</a>；代码在{' '}
        <a class={introLinkClass} href="https://github.com/hyoban" target="_blank" rel="noopener noreferrer">GitHub</a>。你也可以订阅{' '}
        <a class={introLinkClass} href="/rss.xml">RSS</a>、查看 <a class={introLinkClass} href="/llms.txt">LLMs</a> 或我的 <a class={introLinkClass} href="/use">Use</a> 页面。
      </p>
    </section>
    <div class="flex flex-col gap-8">
      {
        postsByYear.map((group) => (
          <section>
            <h2 class="font-mono text-tx-2">{group.year}</h2>
            <ul class="mt-3 flex flex-col gap-3">
              {group.posts.map((post) => (
                <li class="flex justify-between items-center gap-3">
                  <a href={`/${post.data.link}`} class="underline hover:text-cy">
                    {post.data.title}
                  </a>
                  <span class="text-nowrap text-tx-2 font-mono">{formatPostListDate(post.data.pubDate)}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
