---
import Layout from '@/layouts/Layout.astro'
import { formatPostFullDate, getMarkdownEntries, type PostEntry } from '@/utils'
import { render } from 'astro:content'

export async function getStaticPaths() {
  const entries = await getMarkdownEntries()
  return entries.map((entry) => ({
    params: { slug: entry.data.link },
    props: { entry },
  }))
}

type Props = { entry: Awaited<ReturnType<typeof getMarkdownEntries>>[number] }
const { entry } = Astro.props as Props
const post = entry.collection === 'posts' ? (entry as PostEntry) : null
const article = post
  ? {
      author: 'Hyoban',
      publishedTime: post.data.pubDate.toISOString(),
      telegramChannel: '@hyoban',
    }
  : undefined
const { Content } = await render(entry)
---

<Layout title={entry.data.title} description={entry.data.description} article={article}>
  <main class="mx-auto max-w-[65ch] space-y-8">
    <section class="space-y-3">
      <h1>
        {entry.data.title}
      </h1>
      <p class="text-tx-2 flex gap-3">
        {post && (
          <time datetime={post.data.pubDate.toISOString()}>
            {formatPostFullDate(post.data.pubDate)}
          </time>
        )}
        <a href={`/${entry.data.link}.md`}>源文件</a>
        <a href="/">返回</a>
      </p>
    </section>
    <div class="article">
      <article class="prose article__content">
        <Content />
      </article>
    </div>
  </main>
</Layout>
