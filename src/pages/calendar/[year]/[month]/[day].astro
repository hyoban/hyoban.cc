---
import CalendarView from '@/components/CalendarView.astro'
import { getActiveDateKeys, getMoments } from '@/moments'

export async function getStaticPaths() {
  const dateKeys = getActiveDateKeys(await getMoments())

  return dateKeys.map((dateKey) => {
    const year = dateKey.slice(0, 4)
    const month = dateKey.slice(5, 7)
    const day = dateKey.slice(8, 10)

    return {
      params: { day, month, year },
      props: {
        month: Number.parseInt(month, 10),
        selectedDate: dateKey,
        year: Number.parseInt(year, 10),
      },
    }
  })
}

interface Props {
  month: number
  selectedDate: string
  year: number
}

const { month, selectedDate, year } = Astro.props
---

<CalendarView year={year} month={month} selectedDate={selectedDate} />
